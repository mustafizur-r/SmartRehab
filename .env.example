GOOGLE_APPLICATION_CREDENTIALS=vertex_key.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro-preview-06-05

# OpenAI (fallback, optional)
OPENAI_API_KEY=
# Optional (recommended)
OPENAI_MODEL_TRANSLATE=gpt-4o-mini
OPENAI_MODEL_REWRITE=gpt-4o-mini

OPENAI_TIMEOUT_SECONDS=60

# Optional: Ollama fallback preferences (used only if OPENAI_API_KEY is empty/missing)
OLLAMA_MODEL_TRANSLATE=qwen3
OLLAMA_MODEL_REWRITE=qwen3

QUESTIONNAIRE_DATA_DIR=./data/questionnaire
QUESTIONNAIRE_JSONL_PATH=./data/questionnaire/responses.jsonl